---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <h2>> OSINT ARSENAL</h2>
  <p style="line-height: 1.6;">
    A directory of essential tools, search engines, and frameworks used for open-source intelligence gathering and CTF challenges.
  </p>

  <div class="box" style="margin-top: 40px;">
    <h3 style="border: none; color: var(--accent-glow); margin-bottom: 5px;">> SEARCH & REVERSE IMAGE</h3>
    
    <ul style="list-style: none; padding: 0;">
      <li style="border-bottom: 1px dashed var(--border-color); padding: 15px 0;">
        <a href="https://www.google.com/" target="_blank" style="color: var(--accent-glow); font-weight: bold; font-size: 1.1em;">
          Google (Dorks)
        </a>
        <p style="color: var(--text-muted); margin-top: 5px; font-size: 0.9em; margin-bottom: 0;">
          Primary search engine. Essential for advanced search operators (Google Dorks) to uncover exposed directories, specific file types, and cached data.
        </p>
      </li>
      
      <li style="border-bottom: 1px dashed var(--border-color); padding: 15px 0;">
        <a href="https://yandex.com/images/" target="_blank" style="color: var(--accent-glow); font-weight: bold; font-size: 1.1em;">
          Yandex Images
        </a>
        <p style="color: var(--text-muted); margin-top: 5px; font-size: 0.9em; margin-bottom: 0;">
          The most powerful reverse image search engine for facial recognition and identifying locations, particularly effective for Eastern European regions.
        </p>
      </li>

      <li style="border-bottom: 1px dashed var(--border-color); padding: 15px 0;">
        <a href="https://tineye.com/" target="_blank" style="color: var(--accent-glow); font-weight: bold; font-size: 1.1em;">
          TinEye
        </a>
        <p style="color: var(--text-muted); margin-top: 5px; font-size: 0.9em; margin-bottom: 0;">
          Reverse image search tool excellent for finding the oldest chronological upload of an image to track down original sources.
        </p>
      </li>
    </ul>
  </div>

  <div class="box" style="margin-top: 20px;">
    <h3 style="border: none; color: var(--accent-glow); margin-bottom: 5px;">> USERNAME & SOCIAL SEARCH</h3>
    
    <ul style="list-style: none; padding: 0;">
      <li style="border-bottom: 1px dashed var(--border-color); padding: 15px 0;">
        <a href="https://whatsmynameapp.net/" target="_blank" style="color: var(--accent-glow); font-weight: bold; font-size: 1.1em;">
          WhatsMyNameApp
        </a>
        <p style="color: var(--text-muted); margin-top: 5px; font-size: 0.9em; margin-bottom: 0;">
          Web-based username enumeration tool that scans hundreds of sites to find where a specific alias is registered.
        </p>
      </li>

      <li style="border-bottom: 1px dashed var(--border-color); padding: 15px 0;">
        <a href="https://github.com/sherlock-project/sherlock" target="_blank" style="color: var(--accent-glow); font-weight: bold; font-size: 1.1em;">
          Sherlock (CLI)
        </a>
        <p style="color: var(--text-muted); margin-top: 5px; font-size: 0.9em; margin-bottom: 0;">
          Powerful command-line Python tool to hunt down social media accounts by username across social networks.
        </p>
      </li>

      <li style="border-bottom: 1px dashed var(--border-color); padding: 15px 0;">
        <a href="https://www.idcrawl.com/username-search" target="_blank" style="color: var(--accent-glow); font-weight: bold; font-size: 1.1em;">
          IDCrawl
        </a>
        <p style="color: var(--text-muted); margin-top: 5px; font-size: 0.9em; margin-bottom: 0;">
          Free people search engine designed to organize social network profiles, public records, and surface-level data tied to a handle.
        </p>
      </li>

      <li style="border-bottom: 1px dashed var(--border-color); padding: 15px 0;">
        <a href="https://www.social-searcher.com/google-social-search/" target="_blank" style="color: var(--accent-glow); font-weight: bold; font-size: 1.1em;">
          Social Searcher
        </a>
        <p style="color: var(--text-muted); margin-top: 5px; font-size: 0.9em; margin-bottom: 0;">
          Real-time social media search engine to monitor public mentions, keywords, and specific account activities.
        </p>
      </li>
    </ul>
  </div>

  <div class="box" style="margin-top: 20px;">
    <h3 style="border: none; color: var(--accent-glow); margin-bottom: 5px;">> ARCHIVES</h3>
    
    <ul style="list-style: none; padding: 0;">
      <li style="border-bottom: 1px dashed var(--border-color); padding: 15px 0;">
        <a href="https://archive.org/" target="_blank" style="color: var(--accent-glow); font-weight: bold; font-size: 1.1em;">
          Internet Archive (Wayback Machine)
        </a>
        <p style="color: var(--text-muted); margin-top: 5px; font-size: 0.9em; margin-bottom: 0;">
          The ultimate historical web archive. Crucial for viewing deleted websites, past iterations of social profiles, and historical data dumps.
        </p>
      </li>

      <li style="border-bottom: 1px dashed var(--border-color); padding: 15px 0;">
        <a href="https://archive.ph/" target="_blank" style="color: var(--accent-glow); font-weight: bold; font-size: 1.1em;">
          Archive.today
        </a>
        <p style="color: var(--text-muted); margin-top: 5px; font-size: 0.9em; margin-bottom: 0;">
          Creates a permanent snapshot of a webpage. Highly effective for preserving evidence before it gets deleted, and often bypasses standard paywalls.
        </p>
      </li>

      <li style="border-bottom: 1px dashed var(--border-color); padding: 15px 0;">
        <a href="https://ghostarchive.org/" target="_blank" style="color: var(--accent-glow); font-weight: bold; font-size: 1.1em;">
          GhostArchive
        </a>
        <p style="color: var(--text-muted); margin-top: 5px; font-size: 0.9em; margin-bottom: 0;">
          Alternative web and YouTube video archive. Useful for capturing media that might be subject to takedowns.
        </p>
      </li>
    </ul>
  </div>
</Layout>